{
  "name": "@daften/fireflyiii-mcp",
  "version": "0.1.0",
  "description": "MCP server for Firefly III personal finance manager",
  "type": "module",
  "bin": {
    "fireflyiii-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "dev": "dotenv -e .env -- tsx src/index.ts",
    "format": "biome format --write src/",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "dotenv -e .env.test -- vitest run src/tests/integration.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/daften/fireflyiii-mcp.git"
  },
  "keywords": [
    "firefly-iii",
    "mcp",
    "finance",
    "model-context-protocol",
    "claude"
  ],
  "homepage": "https://github.com/daften/fireflyiii-mcp",
  "author": "Dieter Blomme <dieterblomme@gmail.com>",
  "bugs": {
    "url": "https://github.com/daften/fireflyiii-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.0.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
